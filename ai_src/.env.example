# Copie para .env e preencha os valores.
# No GitHub: Settings > Secrets and variables > Actions (Variables para não-sensíveis).

# LLM (obrigatório para OpenAI)
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_PROVIDER=openai  # ou ollama

# Caminhos (opcional; padrão: data/ dentro do projeto)
# DATA_DIR=./data
# VECTOR_DB_PATH=./data/chroma_db
# CONVERSATION_FILE=./data/conversation.json

# Memória e embeddings (opcional)
# MAX_HISTORY_TURNS=5
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
